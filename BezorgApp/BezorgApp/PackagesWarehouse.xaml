<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BezorgApp.PackagesWarehouse"
             Title="PackagesWarehouse"
			 BackgroundColor="FloralWhite">
		
	<Grid Margin="20,0">
		<Grid.RowDefinitions>
			<RowDefinition Height="30"/>

			<RowDefinition Height="30"/>

			<RowDefinition Height="15"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="15"/>

			<RowDefinition Height="30"/>
			<RowDefinition Height="Auto"/>
			<RowDefinition Height="30"/>
			<RowDefinition Height="60"/>
		</Grid.RowDefinitions>


		<Label Text="Poort 5" FontAttributes="Bold"/>
		<BoxView HeightRequest="1" Margin="0,20,0,0"/>
		<Label Text="Rek 1" Grid.Row="1" Padding="0,10,0,0"/>

		<Border Grid.Row="3">
			<Grid ColumnDefinitions="70*, 10*, 30*">
				<Grid.RowDefinitions>
					<RowDefinition Height="50"/>
				</Grid.RowDefinitions>


				<Label Text="01 Adres: Kerkstraat 1 Heerlen" Margin="5,15,0,0" FontSize="Micro"/>
				<Label Text="📦" FontSize="Micro" Grid.Column="1" Margin="5,15,0,0"/>
				<Button Text=">" Grid.Column="2" Margin="20,5" FontSize="Micro"/>
				<BoxView HeightRequest="1" Margin="5,15,0,0"/>
			</Grid>
		</Border>


		<Label Text="Rek 2" Grid.Row="5"/>

		<Border Grid.Row="6">
			<Grid ColumnDefinitions="70*, 10*, 30*">
				<Grid.RowDefinitions>
					<RowDefinition Height="50"/>
					<RowDefinition Height="50"/>

				</Grid.RowDefinitions>

				<Label Text="02 Adres: Kerkstraat 4 Heerlen" Margin="5,15,0,0" FontSize="Micro"/>
				<Label Text="📦" FontSize="Micro" Grid.Column="1" Margin="5,15,0,0"/>
				<BoxView HeightRequest="1" Margin="5,15,0,0"/>
				<Button Text=">" Grid.Column="2" Margin="20,5" FontSize="Micro"/>
				<Label Text="03 Adres: Kerkstraat 4 Heerlen" Margin="5,15,0,0" FontSize="Micro" Grid.Row="2"/>
				<Label Text="📦" FontSize="Micro" Grid.Column="1" Grid.Row="2" Margin="5,15,0,0"/>
				<BoxView HeightRequest="1" Margin="5,15,0,0" Grid.Row="2"/>
				<Button Text=">" Grid.Row="1" Grid.Column="2" Margin="20,5" FontSize="Micro"/>
			</Grid>
		</Border>

		<Button 
		Text="Scannen" 
		Grid.Row="8"
		Clicked="ScannerPage"/>
	</Grid>
</ContentPage>