        </Grid>

        <BoxView HeightRequest="1" Color="#E0E0E0"/>
        <Border StrokeThickness="0">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnAdres1Tapped"/>
            </Border.GestureRecognizers>
            <VerticalStackLayout>
                <Label Text="Kerkstraat 1, 1234AB, Heerlen" Padding="12,10" BackgroundColor="#F5F5F5"/>
                <Label Text="📦4x     ✒️ ja     🕒10:00 - 17:00   >" Padding="12,10" BackgroundColor="White"/>
            </VerticalStackLayout>
        </Border>

        <BoxView HeightRequest="1" Color="#E0E0E0"/>
